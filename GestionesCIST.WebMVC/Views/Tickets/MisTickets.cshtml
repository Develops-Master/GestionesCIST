@model List<TicketClienteViewModel>
@{
    ViewData["Title"] = "Mis Tickets";
    Layout = "_Layout";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-ticket-perforated text-primary"></i> Mis Tickets de Soporte</h2>
        <a asp-action="Crear" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Nuevo Ticket
        </a>
    </div>
    
    @if (!Model.Any())
    {
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-info-circle fs-1"></i>
            <h4>No tienes tickets registrados</h4>
            <p>Crea un nuevo ticket para reportar una incidencia con tu equipo.</p>
            <a asp-action="Crear" class="btn btn-primary">Crear Primer Ticket</a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var ticket in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card ticket-card h-100">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <span class="fw-bold">@ticket.CodigoTicket</span>
                            <span class="badge @GetEstadoClass(ticket.Estado)">@ticket.Estado</span>
                        </div>
                        <div class="card-body">
                            <h6>@ticket.Titulo</h6>
                            <p class="text-muted small">@ticket.Equipo</p>
                            
                            <div class="progress mb-3" style="height: 8px;">
                                <div class="progress-bar @GetProgressClass(ticket.Progreso)" 
                                     style="width: @ticket.Progreso%"></div>
                            </div>
                            
                            <div class="d-flex justify-content-between small text-muted">
                                <span><i class="bi bi-calendar"></i> @ticket.FechaCreacion.ToString("dd/MM/yyyy")</span>
                                <span>
                                    @if (ticket.EstadoKanban != "Pendiente Asignación")
                                    {
                                        <i class="bi bi-gear"></i> @ticket.EstadoKanban
                                    }
                                </span>
                            </div>
                            
                            @if (!string.IsNullOrEmpty(ticket.UltimoComentario))
                            {
                                <div class="mt-3 p-2 bg-light rounded">
                                    <small class="text-muted">Última actualización:</small>
                                    <p class="mb-0 small">@ticket.UltimoComentario</p>
                                </div>
                            }
                        </div>
                        <div class="card-footer">
                            <a asp-action="Detalle" asp-route-id="@ticket.Id" class="btn btn-outline-primary btn-sm w-100">
                                <i class="bi bi-eye"></i> Ver Detalle
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@functions {
    string GetEstadoClass(string estado)
    {
        return estado switch
        {
            "Abierto" => "bg-warning text-dark",
            "Asignado" => "bg-info",
            "EnProgreso" => "bg-primary",
            "Resuelto" => "bg-success",
            "Cerrado" => "bg-secondary",
            _ => "bg-light text-dark"
        };
    }
    
    string GetProgressClass(int progreso)
    {
        return progreso switch
        {
            < 30 => "bg-danger",
            < 70 => "bg-warning",
            _ => "bg-success"
        };
    }
}